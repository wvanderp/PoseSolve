{
  "name": "viewpoint",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite",
    "ct:open": "cypress open --component",
    "ct:run": "cypress run --component",
    "build": "npm run build:wasm && vite build",
    "preview": "vite preview",
    "build:wasm": "wasm-pack build crates/solver --target web --release",
    "lint": "tsc --noEmit",
    "test:vite": "vitest run --coverage",
    "test": "npm run lint && npm run test:vite && npm run ct:run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "comlink": "^4.4.2",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "@cypress/react": "^9.0.1",
    "@cypress/vite-dev-server": "^7.2.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "cypress": "^15.11.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
